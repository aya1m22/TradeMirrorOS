# Backend / Supabase Edge Function secrets — set via `supabase secrets set NAME=value`.
# These are NEVER exposed to the browser. Do NOT prefix with VITE_.

# Auto-injected by the Supabase Edge runtime (no need to set in production):
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Brevo transactional email (https://app.brevo.com/settings/keys/api) ──────
# Powers invite, password-reset, and milestone-alert emails. Email is best-effort
# everywhere: when these are unset the invite flow still saves the invitation and
# returns the link for manual delivery, and alerts still flip overdue in-app.
BREVO_API_KEY=
# Must be a VERIFIED sender in your Brevo account (Senders → add + verify).
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=TradeMirror OS

# Canonical app URL for the links in emails. Optional — falls back to the request
# Origin when unset (fine for local dev). Set to your deployed frontend URL in prod.
# APP_URL=https://your-app.vercel.app

# Milestone-alert recipient (SuperAdmin).
ALERT_TO_EMAIL=
