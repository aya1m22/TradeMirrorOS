# Backend / Supabase Edge Function secrets — set via `supabase secrets set NAME=value`.
# These are NEVER exposed to the browser. Do NOT prefix with VITE_.

# Auto-injected by the Supabase Edge runtime (no need to set in production):
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# TODO(secret): Resend API key for outbound email — used by the milestone-alerts
# Edge Function and (optionally) invite-user. Obtain at resend.com.
RESEND_API_KEY=

# invite-user email is OPT-IN and has no default sender, so dev never depends on a
# domain you don't own: a custom invitation email is sent ONLY when BOTH
# RESEND_API_KEY and INVITE_FROM_EMAIL (a VERIFIED Resend domain) are set. Leave
# INVITE_FROM_EMAIL unset in dev — the function still creates the user and returns
# the invite link for manual delivery.
# INVITE_FROM_EMAIL=TradeMirror OS <no-reply@yourverifieddomain.com>

# Milestone alert email addressing (PRD §11).
ALERT_FROM_EMAIL=alerts@chipafarm.com
# Recipient (SuperAdmin). TODO(secret): set to the owner's address.
ALERT_TO_EMAIL=
