# Frontend env — copy to `.env` (gitignored). Client-safe values only.
# IMPORTANT: Vite bakes VITE_* vars into the bundle at BUILD time, so these
# must be set in the host's build environment for production deploys.

# Required.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — true runs on local fixtures instead of Supabase (default: false).
VITE_USE_MOCKS=false

# NEVER put the service_role key in any VITE_-prefixed var — it bypasses RLS
# and would be exposed in the browser bundle. Keep it server-side only.
